  <section class="route-section" id="route-planner">
    <% if (mapsApiKey) { %>
      <div class="map-frame">
        <div id="map"></div>
      </div>

      <div class="page-shell route-overlay">
        <div class="route-copy">
          <p class="section-kicker">Visit Context</p>
          <h2 class="section-title" id="routeTitle">Dein Weg zum Serenity Center.</h2>
          <p class="section-copy">Starte die Berechnung mit deinem Standort und sieh Distanz und Reisezeit direkt auf der Karte.</p>
        </div>

        <div class="route-layout">
          <aside class="route-panel">
            <form class="controls" id="routeForm">
              <button class="btn btn-primary" id="routeBtn" type="submit" disabled>Route berechnen</button>
            </form>

            <div class="route-result" id="routeResult" aria-live="polite">
              <div class="route-metric">
                <span>Distanz</span>
                <strong id="resultDistance">-</strong>
              </div>
              <div class="route-metric">
                <span>Reisezeit</span>
                <strong id="resultDuration">-</strong>
              </div>
            </div>
          </aside>
        </div>
      </div>

        <script>
          const DEFAULT_CENTER = { lat: 51.1657, lng: 10.4515 };
          const Serenity_MAP_STYLES = [
            { elementType: "geometry", stylers: [{ color: "#101722" }] },
            { elementType: "labels.icon", stylers: [{ visibility: "off" }] },
            { elementType: "labels.text.fill", stylers: [{ color: "#8b98aa" }] },
            { elementType: "labels.text.stroke", stylers: [{ color: "#070b10" }, { weight: 2 }] },
            { featureType: "administrative", elementType: "geometry.stroke", stylers: [{ color: "#263243" }] },
            { featureType: "landscape", elementType: "geometry", stylers: [{ color: "#0d141e" }] },
            { featureType: "poi", stylers: [{ visibility: "off" }] },
            { featureType: "road", elementType: "geometry", stylers: [{ color: "#202b3a" }] },
            { featureType: "road", elementType: "geometry.stroke", stylers: [{ color: "#080d13" }] },
            { featureType: "road.arterial", elementType: "geometry", stylers: [{ color: "#28384d" }] },
            { featureType: "road.highway", elementType: "geometry", stylers: [{ color: "#1c69d4" }, { lightness: -38 }, { saturation: -12 }] },
            { featureType: "road.highway", elementType: "geometry.stroke", stylers: [{ color: "#8fc0ff" }, { lightness: -35 }] },
            { featureType: "road.local", elementType: "labels.text.fill", stylers: [{ color: "#647184" }] },
            { featureType: "transit", stylers: [{ visibility: "off" }] },
            { featureType: "water", elementType: "geometry", stylers: [{ color: "#050b13" }] },
            { featureType: "water", elementType: "labels.text.fill", stylers: [{ color: "#526073" }] },
          ];
          const Serenity_PIN_SVG =
            '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64">' +
              '<circle cx="32" cy="32" r="28" fill="#0b0f14" stroke="#8fc0ff" stroke-width="3"/>' +
              '<circle cx="32" cy="32" r="18" fill="#fff"/>' +
              '<path d="M32 14a18 18 0 0 1 18 18H32z" fill="#1c69d4"/>' +
              '<path d="M14 32a18 18 0 0 1 18-18v18z" fill="#fff"/>' +
              '<path d="M32 32h18a18 18 0 0 1-18 18z" fill="#fff"/>' +
              '<path d="M14 32h18v18a18 18 0 0 1-18-18z" fill="#1c69d4"/>' +
              '<circle cx="32" cy="32" r="18" fill="none" stroke="#0b0f14" stroke-width="2"/>' +
            '</svg>';
          const SPORTS_CAR_SVG =
            '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 72 112" aria-hidden="true">' +
              '<rect x="14" y="10" width="44" height="92" rx="15" fill="#1c69d4" stroke="#fff" stroke-width="4"/>' +
              '<rect x="22" y="22" width="28" height="22" rx="5" fill="#d9f0ff" opacity=".92"/>' +
              '<rect x="22" y="66" width="28" height="22" rx="5" fill="#0b2349" opacity=".88"/>' +
              '<path d="M17 46h8M47 46h8M17 78h8M47 78h8" stroke="#8fc0ff" stroke-width="4" stroke-linecap="round"/>' +
              '<circle cx="23" cy="16" r="3" fill="#fff6a6"/>' +
              '<circle cx="49" cy="16" r="3" fill="#fff6a6"/>' +
              '<circle cx="23" cy="96" r="3" fill="#ff6b6b"/>' +
              '<circle cx="49" cy="96" r="3" fill="#ff6b6b"/>' +
              '<path d="M28 54h16" stroke="#07111c" stroke-width="4" stroke-linecap="round" opacity=".65"/>' +
            '</svg>';

          let map, directionsService, directionsRenderer;
          let carMarker, destinationMarker;
          let animationFrame = null;
          let destinations = [];
          let currentLocationOrigin = null;

          function svgDataUrl(svg) {
            return "data:image/svg+xml;charset=UTF-8," + encodeURIComponent(svg);
          }

          function createSportsCarMarker(initialPosition, targetMap) {
            function toLatLng(position) {
              if (position && typeof position.lat === "function") return position;
              return new google.maps.LatLng(position.lat, position.lng);
            }

            class SportsCarOverlay extends google.maps.OverlayView {
              constructor(position) {
                super();
                this.position = toLatLng(position);
                this.rotation = 0;
                this.div = null;
              }

              onAdd() {
                this.div = document.createElement("div");
                this.div.className = "route-car-marker hidden";
                this.div.innerHTML = SPORTS_CAR_SVG;
                this.getPanes().overlayMouseTarget.appendChild(this.div);
              }

              draw() {
                if (!this.div) return;
                const projection = this.getProjection();
                if (!projection) return;
                const point = projection.fromLatLngToDivPixel(this.position);
                this.div.style.left = point.x + "px";
                this.div.style.top = point.y + "px";
                this.div.style.transform = `translate(-50%, -50%) rotate(${this.rotation}deg)`;
              }

              onRemove() {
                if (this.div) {
                  this.div.remove();
                  this.div = null;
                }
              }

              setPosition(position) {
                this.position = toLatLng(position);
                this.draw();
              }

              setRotation(rotation) {
                this.rotation = rotation || 0;
                this.draw();
              }

              show() {
                if (this.div) this.div.classList.remove("hidden");
              }

              hide() {
                if (this.div) this.div.classList.add("hidden");
              }
            }

            const overlay = new SportsCarOverlay(initialPosition);
            overlay.setMap(targetMap);
            return overlay;
          }

          function initMap() {
            map = new google.maps.Map(document.getElementById("map"), {
              zoom: 5,
              center: DEFAULT_CENTER,
              backgroundColor: "#070b10",
              clickableIcons: false,
              disableDefaultUI: true,
              gestureHandling: "cooperative",
              styles: Serenity_MAP_STYLES,
              zoomControl: false,
            });

            directionsService = new google.maps.DirectionsService();
            directionsRenderer = new google.maps.DirectionsRenderer({
              suppressMarkers: true,
              preserveViewport: true,
              polylineOptions: {
                strokeColor: "#8FC0FF",
                strokeOpacity: 0.95,
                strokeWeight: 6,
              },
            });
            directionsRenderer.setMap(map);

            carMarker = createSportsCarMarker(DEFAULT_CENTER, map);
            carMarker.hide();

            loadDestinations();
          }

          function selectedDestination() {
            return destinations[0] || null;
          }

          async function loadDestinations() {
            const routeBtn = document.getElementById("routeBtn");

            try {
              const response = await fetch("/api/destinations");
              if (!response.ok) throw new Error("Destinations request failed");
              destinations = await response.json();

              routeBtn.disabled = destinations.length === 0;
              updateRouteTitle();
            } catch (err) {
              console.error(err);
              routeBtn.disabled = true;
            }
          }

          function updateRouteTitle() {
            const destination = selectedDestination();
            const routeTitle = document.getElementById("routeTitle");
            if (!routeTitle) return;
            routeTitle.textContent = destination
              ? `Dein Ziel: ${destination.name || destination.label}`
              : "Dein Ziel: Serenity Wellness Center";
          }

          function updateDestinationMarker(position, title) {
            if (!position) return;

            if (destinationMarker) {
              destinationMarker.setMap(null);
            }

            destinationMarker = new google.maps.Marker({
              position,
              map,
              title,
              icon: {
                url: svgDataUrl(Serenity_PIN_SVG),
                scaledSize: new google.maps.Size(56, 56),
                anchor: new google.maps.Point(28, 28),
              },
              zIndex: 5,
            });

            destinationMarker.addListener("click", () => {
              const streetView = map.getStreetView();
              streetView.setPosition(position);
              streetView.setPov({ heading: 265, pitch: 0 });
              streetView.setVisible(true);
            });
          }

          function animateCar(path) {
            if (!path || path.length < 2) return;
            if (animationFrame) cancelAnimationFrame(animationFrame);

            carMarker.show();

            const DRIVE_DURATION = 8000;
            const ZOOM_DURATION = 1500;
            const FINAL_ZOOM = 13;

            const startZoom = map.getZoom();
            const start = performance.now();

            function easeInOutCubic(x) {
              return x < 0.5 ? 4 * x * x * x : 1 - Math.pow(-2 * x + 2, 3) / 2;
            }

            function positionAt(progress) {
              const idx = progress * (path.length - 1);
              const i = Math.floor(idx);
              const frac = idx - i;
              const p1 = path[i];
              const p2 = path[Math.min(i + 1, path.length - 1)];
              return {
                lat: p1.lat() + (p2.lat() - p1.lat()) * frac,
                lng: p1.lng() + (p2.lng() - p1.lng()) * frac,
                bearing: Math.atan2(p2.lng() - p1.lng(), p2.lat() - p1.lat()) * 180 / Math.PI,
              };
            }

            function step(now) {
              const elapsed = now - start;

              if (elapsed < DRIVE_DURATION) {
                const progress = easeInOutCubic(elapsed / DRIVE_DURATION);
                const pos = positionAt(progress);
                carMarker.setPosition({ lat: pos.lat, lng: pos.lng });
                carMarker.setRotation(pos.bearing);
                animationFrame = requestAnimationFrame(step);
              } else {
                const destination = selectedDestination();
                carMarker.setPosition(path[path.length - 1]);
                animationFrame = null;
                zoomIn(performance.now(), path[path.length - 1], destination ? destination.name : "Serenity Ziel");
              }
            }

            function zoomIn(zoomStart, destinationPosition, destinationTitle) {
              function zoomStep(now) {
                const t = Math.min(1, (now - zoomStart) / ZOOM_DURATION);
                const eased = easeInOutCubic(t);
                map.setZoom(startZoom + eased * (FINAL_ZOOM - startZoom));
                map.setCenter(destinationPosition);
                if (t < 1) animationFrame = requestAnimationFrame(zoomStep);
                else {
                  updateDestinationMarker(destinationPosition, destinationTitle);
                  animationFrame = null;
                }
              }
              animationFrame = requestAnimationFrame(zoomStep);
            }

            animationFrame = requestAnimationFrame(step);
          }

          function requestCurrentLocation() {
            return new Promise((resolve, reject) => {
              if (!navigator.geolocation) {
                reject(new Error("Geolocation wird von diesem Browser nicht unterstützt."));
                return;
              }

              navigator.geolocation.getCurrentPosition(
                (pos) => {
                  resolve({ lat: pos.coords.latitude, lng: pos.coords.longitude });
                },
                () => reject(new Error("Standortzugriff wurde verweigert.")),
                { enableHighAccuracy: true, timeout: 10000, maximumAge: 60000 }
              );
            });
          }

          async function resolveOrigin() {
            if (currentLocationOrigin) {
              return currentLocationOrigin;
            }

            currentLocationOrigin = await requestCurrentLocation();
            return currentLocationOrigin;
          }

          function formatDuration(seconds) {
            const totalMinutes = Math.max(1, Math.round(seconds / 60));
            const hours = Math.floor(totalMinutes / 60);
            const minutes = totalMinutes % 60;

            if (!hours) return `${minutes} min`;
            if (!minutes) return `${hours}h`;
            return `${hours}h ${minutes} min`;
          }

          async function calculateRoute() {
            const destination = selectedDestination();
            const routeBtn = document.getElementById("routeBtn");

            if (!destination) {
              return;
            }

            routeBtn.disabled = true;
            routeBtn.textContent = "Route wird berechnet";

            try {
              const origin = await resolveOrigin();

              directionsService.route({
                origin,
                destination: destination.destination || destination.value,
                travelMode: google.maps.TravelMode.DRIVING,
              }, (result, status) => {
                routeBtn.disabled = false;
                routeBtn.textContent = "Route berechnen";

                if (status === "OK") {
                  directionsRenderer.setDirections(result);
                  const route = result.routes[0];
                  const leg = route.legs[0];

                  document.getElementById("resultDistance").textContent = leg.distance ? leg.distance.text : "-";
                  document.getElementById("resultDuration").textContent = leg.duration ? formatDuration(leg.duration.value) : "-";
                  updateDestinationMarker(leg.end_location, destination.name || destination.label);

                  if (route.bounds) {
                    map.fitBounds(route.bounds, { top: 380, right: 120, bottom: 160, left: 120 });
                    google.maps.event.addListenerOnce(map, "idle", () => animateCar(route.overview_path));
                  } else {
                    animateCar(route.overview_path);
                  }
                }
              });
            } catch (err) {
              routeBtn.disabled = false;
              routeBtn.textContent = "Route starten";
            }
          }

          document.getElementById("routeForm").addEventListener("submit", (event) => {
            event.preventDefault();
            calculateRoute();
          });
        </script>
        <script src="https://maps.googleapis.com/maps/api/js?key=<%= mapsApiKey %>&v=weekly&callback=initMap" async defer></script>
      <% } else { %>
      <div class="page-shell route-overlay">
        <div class="route-copy">
          <p class="section-kicker">Route</p>
          <h2 class="section-title" id="routeTitle">Dein Ziel: Serenity Wellness Center</h2>
          <p class="section-copy">Standort nutzen, Startadresse eingeben und die Anreise zum Serenity Center direkt auf der Karte planen.</p>
        </div>
        <div class="no-key">
          <h3>API-Key erforderlich</h3>
          <p>Bitte konfigurieren Sie den <code>GOOGLE_MAPS_API_KEY</code> in Ihrer Umgebung.</p>
        </div>
      </div>
    <% } %>
  </section>
</main>

<script>
  (function () {
    const experience = document.querySelector('.experience-section');
    const merchCarousel = document.querySelector('[data-merch-carousel]');
    const merchPrev = document.querySelector('[data-merch-prev]');
    const merchNext = document.querySelector('[data-merch-next]');
    const merchAutoScrollDelay = 5000;
    const merchAutoScrollCount = 5;
    let snapping = false;
    let merchAutoScrollTimer = 0;

    function setupInfiniteAftercareCarousel() {
      if (!merchCarousel) return;

      const originalCards = Array.from(merchCarousel.children);
      if (originalCards.length < 2) return;

      const beforeCards = document.createDocumentFragment();
      const afterCards = document.createDocumentFragment();

      originalCards.forEach(function (card) {
        const beforeClone = card.cloneNode(true);
        const afterClone = card.cloneNode(true);

        [beforeClone, afterClone].forEach(function (clone) {
          clone.setAttribute('aria-hidden', 'true');
          clone.tabIndex = -1;
          clone.dataset.merchClone = 'true';
        });

        beforeCards.appendChild(beforeClone);
        afterCards.appendChild(afterClone);
      });

      merchCarousel.insertBefore(beforeCards, merchCarousel.firstChild);
      merchCarousel.appendChild(afterCards);

      let originalStart = 0;
      let setWidth = 0;
      let scrollFrame = 0;
      let isJumping = false;

      function measureCarousel() {
        const cards = merchCarousel.children;
        const firstOriginal = cards[originalCards.length];
        const firstAfterOriginals = cards[originalCards.length * 2];

        if (!firstOriginal || !firstAfterOriginals) return;

        originalStart = firstOriginal.offsetLeft - merchCarousel.offsetLeft;
        setWidth = firstAfterOriginals.offsetLeft - firstOriginal.offsetLeft;
      }

      function jumpTo(left) {
        isJumping = true;
        merchCarousel.scrollTo({ left, behavior: 'auto' });
        requestAnimationFrame(function () {
          isJumping = false;
        });
      }

      function normalizeScrollPosition() {
        scrollFrame = 0;
        if (isJumping || !setWidth) return;

        const left = merchCarousel.scrollLeft;
        const loopStart = originalStart - setWidth;
        const loopEnd = originalStart + setWidth;

        if (left <= loopStart + 1) {
          jumpTo(left + setWidth);
        } else if (left >= loopEnd - 1) {
          jumpTo(left - setWidth);
        }
      }

      function scheduleNormalize() {
        if (scrollFrame) return;
        scrollFrame = requestAnimationFrame(normalizeScrollPosition);
      }

      measureCarousel();
      jumpTo(originalStart);
      merchCarousel.addEventListener('scroll', scheduleNormalize, { passive: true });

      window.addEventListener('resize', function () {
        const progress = setWidth ? (merchCarousel.scrollLeft - originalStart) / setWidth : 0;
        measureCarousel();
        jumpTo(originalStart + ((progress % 1 + 1) % 1) * setWidth);
      });
    }

    function getAftercareCardStep() {
      if (!merchCarousel) return 280;

      const firstCard = merchCarousel.querySelector('.merch-card');
      if (!firstCard) return Math.max(280, merchCarousel.clientWidth * 0.82);

      const styles = window.getComputedStyle(merchCarousel);
      const gap = Number.parseFloat(styles.columnGap || styles.gap) || 0;

      return firstCard.getBoundingClientRect().width + gap;
    }

    function scrollAftercareCarousel(direction, itemCount) {
      if (!merchCarousel) return;
      merchCarousel.scrollBy({
        left: direction * getAftercareCardStep() * (itemCount || 1),
        behavior: 'smooth',
      });
    }

    function startAftercareAutoScroll() {
      if (!merchCarousel) return;

      window.clearInterval(merchAutoScrollTimer);
      merchAutoScrollTimer = window.setInterval(function () {
        scrollAftercareCarousel(1, merchAutoScrollCount);
      }, merchAutoScrollDelay);
    }

    setupInfiniteAftercareCarousel();
    startAftercareAutoScroll();

    if (merchPrev) {
      merchPrev.addEventListener('click', function () {
        scrollAftercareCarousel(-1);
        startAftercareAutoScroll();
      });
    }

    if (merchNext) {
      merchNext.addEventListener('click', function () {
        scrollAftercareCarousel(1);
        startAftercareAutoScroll();
      });
    }

    window.addEventListener('wheel', function (event) {
      if (!experience || snapping) return;
      const experienceTop = experience.offsetTop;
      if (window.scrollY < experienceTop && event.deltaY > 0) {
        snapping = true;
        event.preventDefault();
        window.scrollTo({ top: experienceTop, behavior: 'smooth' });
        setTimeout(function () { snapping = false; }, 900);
      }
    }, { passive: false });
  })();
</script>
