<%
  const homeImageBase = "/static/images";
  const merchImageBase = "/api/aftercare/assets/aftercare-shop";

  const merchPreviewProducts = [
    { name: "Heated Neck Wrap", variant: "Warmth", slug: "heated-neck-wrap", category: "Recovery", price: "34,90 EUR", description: "Reusable warmth for neck and shoulder recovery.", image: "heated-neck-wrap.svg" },
    { name: "Ergonomic Neck Pillow", variant: "Travel", slug: "ergonomic-neck-pillow", category: "Comfort", price: "29,90 EUR", description: "Compact support for the way home after treatment.", image: "ergonomic-neck-pillow.svg" },
    { name: "Lavender Aroma Oil", variant: "Calm", slug: "lavender-aroma-oil", category: "Aroma", price: "18,50 EUR", description: "A calming aroma companion for aftercare routines.", image: "lavender-aroma-oil.svg" },
    { name: "Stretching Band", variant: "Mobility", slug: "stretching-band", category: "Mobility", price: "16,90 EUR", description: "Light resistance support for guided stretching.", image: "stretching-band.svg" },
    { name: "Recovery Massage Ball", variant: "Trigger Point", slug: "recovery-massage-ball", category: "Mobility", price: "12,90 EUR", description: "Focused pressure support between visits.", image: "recovery-massage-ball.svg" },
    { name: "Herbal Warmth Pack", variant: "Relax", slug: "herbal-warmth-pack", category: "Recovery", price: "24,90 EUR", description: "Gentle warmth with a reusable herbal insert.", image: "herbal-warmth-pack.svg" },
  ];
%>
<style>
  /* Home-specific layouts only.
     Tokens, reset, fonts, .page-shell, .site-nav (both variants), .site-footer,
     .section-*, .btn*, .field/.input, .card* live in /static/ci/wellness-ci.css. */

  .hero {
    position: relative;
    min-height: 100vh;
    width: 100%;
    overflow: hidden;
    color: #fff;
    background: #000;
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.22) 0%, rgba(0, 0, 0, 0.18) 45%, rgba(0, 0, 0, 0.62) 100%),
      linear-gradient(90deg, rgba(0, 0, 0, 0.38), rgba(0, 0, 0, 0.05) 55%, rgba(0, 0, 0, 0.3));
  }

  .hero-overlay {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 130px 24px 88px;
  }

  .hero-title {
    margin: 0;
    font-size: clamp(2.7rem, 7vw, 6.4rem);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.02;
    text-shadow: 0 8px 30px rgba(0, 0, 0, 0.45);
  }

  .hero-subtitle {
    margin: 18px 0 0;
    color: rgba(255, 255, 255, 0.86);
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-overlay .btn-cta {
    margin-top: 34px;
  }

  .scroll-hint {
    position: absolute;
    bottom: 34px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .experience-section {
    background: #fff;
    padding: clamp(76px, 9vw, 124px) 0 0;
  }

  .vehicle-hero {
    margin-top: 0;
    margin-left: calc(50% - 50vw);
    position: relative;
    width: 100vw;
    min-height: 100vh;
    min-height: 100svh;
    overflow: hidden;
    background: #070b10;
    color: #fff;
  }

  .vehicle-backdrop {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .vehicle-hero::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(6, 10, 16, 0.12) 0%, rgba(6, 10, 16, 0.22) 48%, rgba(6, 10, 16, 0.76) 100%),
      linear-gradient(90deg, rgba(6, 10, 16, 0.46) 0%, rgba(6, 10, 16, 0.08) 52%, rgba(6, 10, 16, 0.24) 100%);
    pointer-events: none;
  }

  .vehicle-hotspot {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: block;
    outline: none;
  }

  .vehicle-hotspot--3er {
    clip-path: polygon(1% 41%, 62% 40%, 76% 53%, 77% 77%, 3% 82%, 0 65%);
  }

  .vehicle-hotspot--x5 {
    clip-path: polygon(42% 31%, 100% 31%, 100% 82%, 47% 84%, 39% 68%);
  }

  .vehicle-hotspot img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.96;
    filter: brightness(0.58) saturate(0.92) contrast(1.03);
    transform: scale(1);
    transition: transform 0.28s ease, filter 0.28s ease, opacity 0.28s ease;
    pointer-events: none;
    will-change: transform, filter;
  }

  .vehicle-hotspot--3er img {
    transform-origin: 35% 64%;
  }

  .vehicle-hotspot--x5 img {
    transform-origin: 83% 61%;
  }

  .vehicle-hotspot:hover img,
  .vehicle-hotspot:focus-visible img {
    opacity: 1;
    filter: brightness(1.08) saturate(1.08) contrast(1.04) drop-shadow(0 18px 26px rgba(0, 0, 0, 0.38));
    transform: scale(1.026);
  }

  .vehicle-label {
    position: absolute;
    z-index: 3;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 0 16px;
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: var(--radius);
    background: rgba(7, 12, 18, 0.76);
    color: #fff;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.28);
    backdrop-filter: blur(14px);
    opacity: 0;
    pointer-events: none;
    transform: translateY(6px);
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease, background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .vehicle-label::after {
    content: "";
    width: 8px;
    height: 8px;
    border-top: 2px solid currentColor;
    border-right: 2px solid currentColor;
    transform: rotate(45deg);
  }

  .vehicle-hotspot--3er .vehicle-label {
    left: 14%;
    bottom: 24%;
  }

  .vehicle-hotspot--x5 .vehicle-label {
    right: 13%;
    bottom: 24%;
  }

  .vehicle-hotspot:hover .vehicle-label,
  .vehicle-hotspot:focus-visible .vehicle-label {
    background: var(--accent);
    border-color: rgba(255, 255, 255, 0.44);
    opacity: 1;
    transform: translateY(-3px);
    visibility: visible;
  }

  .vehicle-hotspot:focus-visible .vehicle-label {
    box-shadow: 0 0 0 3px rgba(143, 192, 255, 0.42), 0 16px 36px rgba(0, 0, 0, 0.28);
  }

  .stage-index {
    position: absolute;
    top: 28px;
    left: 28px;
    z-index: 3;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .stage-caption {
    position: absolute;
    left: 50%;
    bottom: clamp(24px, 4vw, 46px);
    z-index: 3;
    width: min(92vw, 1240px);
    transform: translateX(-50%);
    text-align: center;
    pointer-events: none;
  }

  .stage-caption h4 {
    margin: 0;
    color: #fff;
    font-size: 3.35rem;
    font-weight: 700;
    letter-spacing: 0;
    line-height: 0.96;
    white-space: nowrap;
    text-shadow: 0 18px 46px rgba(0, 0, 0, 0.45);
  }

  .service-rail {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(20px, 3vw, 36px);
    margin-bottom: clamp(52px, 8vw, 96px);
  }

  .service-intro {
    margin-bottom: 34px;
  }

  .service-intro .section-copy {
    max-width: 620px;
  }

  .service-link {
    min-height: 260px;
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto auto auto 1fr;
    row-gap: 12px;
    padding: 18px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.78);
    color: var(--ink);
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }

  .service-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    background: #e7ebf0;
  }

  .service-link:hover {
    background: #fff;
    border-color: rgba(17, 24, 39, 0.24);
    transform: translateY(-2px);
  }

  .service-number {
    color: var(--accent);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  .service-link h3 {
    margin: 0;
    font-size: 1.18rem;
    font-weight: 700;
    line-height: 1.18;
  }

  .service-link p {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .merch-preview-section {
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: flex-start;
    background: #fff;
    padding: clamp(32px, 5vw, 64px) 0 clamp(76px, 9vw, 124px);
  }

  .merch-preview-section .page-shell {
    width: min(1180px, calc(100% - 40px));
  }

  .merch-preview-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 28px;
    margin-bottom: 36px;
  }

  .merch-preview-head .section-copy {
    max-width: 520px;
  }

  .merch-preview-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .merch-carousel-button {
    width: 44px;
    height: 44px;
    border: 1px solid rgba(17, 24, 39, 0.2);
    background: #fff;
    color: var(--ink);
    cursor: pointer;
    font-size: 1.2rem;
    font-weight: 700;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .merch-carousel-button:hover {
    background: var(--ink);
    color: #fff;
    transform: translateY(-2px);
  }

  .merch-grid {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(280px, calc((100% - 36px) / 3));
    gap: 18px;
    overflow-x: auto;
    overscroll-behavior-inline: contain;
    padding: 0 0 12px;
    scroll-padding-inline: 2px;
    scroll-snap-type: inline mandatory;
    scrollbar-width: thin;
  }

  .merch-grid .merch-card {
    scroll-snap-align: start;
  }

  .merch-preview-section .merch-card {
    position: relative;
    display: block;
    height: clamp(260px, 32vw, 380px);
    border-radius: 12px;
    overflow: hidden;
    background: #f1f5f9;
    color: #fff;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }

  .merch-preview-section .merch-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.14);
  }

  .merch-preview-section .merch-card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .merch-preview-section .merch-card:hover .merch-card-img {
    transform: scale(1.06);
  }

  .merch-preview-section .merch-card-overlay {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    padding: 56px 20px 20px;
    background: linear-gradient(to top, rgba(5, 10, 18, 0.88) 0%, rgba(5, 10, 18, 0.42) 55%, transparent 100%);
    color: #fff;
    transition: padding-bottom 0.25s ease;
  }

  .merch-preview-section .merch-card:hover .merch-card-overlay {
    padding-bottom: 68px;
  }

  .merch-preview-section .merch-card-category {
    display: block;
    margin-bottom: 5px;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .merch-preview-section .merch-card-name {
    display: -webkit-box;
    margin: 0 0 5px;
    overflow: hidden;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .merch-preview-section .merch-card-price {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1rem;
    font-weight: 800;
  }

  .heritage-section {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    min-height: 100svh;
    background: #070b10;
    color: #fff;
  }

  .heritage-video {
    position: absolute;
    top: 0;
    right: 0;
    width: min(58%, 860px);
    height: 100%;
    object-fit: cover;
    opacity: 0.46;
  }

  .heritage-yt {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 1.5rem 0;
    border-radius: 4px;
    overflow: hidden;
  }

  .heritage-yt iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .yt-stage-section {
    background: #fff;
    padding: clamp(48px, 7vw, 96px) 0;
  }

  .yt-stage-section .yt-stage-header {
    margin-bottom: 2rem;
  }

  .heritage-section::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, #070b10 0%, rgba(7, 11, 16, 0.94) 36%, rgba(7, 11, 16, 0.5) 68%, rgba(7, 11, 16, 0.8) 100%),
      linear-gradient(180deg, rgba(7, 11, 16, 0.1), rgba(7, 11, 16, 0.82));
  }

  .heritage-content {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    min-height: 100svh;
    display: grid;
    grid-template-columns: minmax(0, 0.76fr) minmax(170px, 0.24fr);
    gap: 42px;
    align-items: center;
    padding: clamp(112px, 12vw, 172px) 0;
  }

  .heritage-content .section-kicker {
    color: #8fc0ff;
  }

  .heritage-title {
    margin: 0;
    max-width: 790px;
    font-size: clamp(2.2rem, 5vw, 5.15rem);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 0.98;
  }

  .heritage-copy {
    max-width: 620px;
    margin: 24px 0 0;
    color: rgba(255, 255, 255, 0.74);
    font-size: 1.02rem;
  }

  .heritage-ledger {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    max-width: 860px;
    margin-top: 46px;
    border-top: 1px solid rgba(255, 255, 255, 0.24);
    border-bottom: 1px solid rgba(255, 255, 255, 0.24);
  }

  .ledger-item {
    padding: 22px 22px 22px 0;
    border-right: 1px solid rgba(255, 255, 255, 0.2);
  }

  .ledger-item + .ledger-item {
    padding-left: 22px;
  }

  .ledger-item:last-child {
    border-right: 0;
  }

  .ledger-item span {
    display: block;
    color: #8fc0ff;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .ledger-item strong {
    display: block;
    margin-top: 10px;
    font-size: 1.16rem;
    font-weight: 700;
    line-height: 1.18;
  }

  .heritage-mark {
    justify-self: end;
    padding-left: 28px;
    border-left: 1px solid rgba(255, 255, 255, 0.26);
    text-align: right;
  }

  .heritage-mark strong {
    display: block;
    font-size: clamp(3.8rem, 8vw, 8rem);
    font-weight: 200;
    line-height: 0.82;
  }

  .heritage-mark span {
    display: block;
    margin-top: 16px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .route-section {
    position: relative;
    overflow: hidden;
    background: #070b10;
    color: #fff;
    min-height: 100vh;
    min-height: 100svh;
    padding: 0;
    scroll-margin-top: 0;
  }

  .route-section::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(90deg, rgba(7, 11, 16, 0.9) 0%, rgba(7, 11, 16, 0.66) 31%, rgba(7, 11, 16, 0.12) 68%, rgba(7, 11, 16, 0.32) 100%),
      linear-gradient(180deg, rgba(7, 11, 16, 0.72) 0%, rgba(7, 11, 16, 0.04) 38%, rgba(7, 11, 16, 0.5) 100%);
    pointer-events: none;
  }

  .route-section .page-shell {
    width: min(1180px, calc(100% - 40px));
  }

  .route-overlay {
    position: relative;
    z-index: 2;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding: clamp(28px, 4vw, 58px) 0;
    pointer-events: none;
  }

  .route-copy {
    max-width: 760px;
    text-shadow: 0 16px 42px rgba(0, 0, 0, 0.48);
    pointer-events: auto;
  }

  .route-section .section-kicker {
    color: #8fc0ff;
  }

  .route-section .section-title {
    max-width: 980px;
    color: #fff;
  }

  .route-section .section-copy {
    max-width: 640px;
    color: rgba(255, 255, 255, 0.74);
  }

  .route-layout {
    width: min(720px, 100%);
    margin-top: clamp(13px, 2vw, 24px);
    pointer-events: auto;
  }

  .route-panel {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 10px;
    align-items: stretch;
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: #fff;
    box-shadow: none;
    backdrop-filter: none;
    overflow: visible;
  }

  .controls {
    display: grid;
    grid-template-columns: 1fr;
    align-items: stretch;
  }

  .route-status {
    display: block;
    margin-top: 10px;
    font-size: 0.95rem;
    line-height: 1.4;
    white-space: normal;
  }

  .route-status.error {
    color: #ffb4ab;
  }

  .route-status.success {
    color: #8fdab5;
  }

  .route-result {
    position: absolute;
    top: clamp(28px, 4vw, 58px);
    right: 0;
    display: grid;
    width: min(430px, 36vw);
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
    margin: 0;
    padding: 14px 18px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius);
    background: rgba(7, 12, 18, 0.38);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(18px);
    opacity: 1;
    pointer-events: auto;
  }

  .route-metric {
    min-width: 0;
  }

  .route-metric span {
    display: block;
    color: #8fc0ff;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .route-metric strong {
    display: block;
    color: #fff;
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .map-frame {
    position: absolute;
    inset: 0;
    z-index: 0;
    min-height: 100vh;
    min-height: 100svh;
    height: 100%;
    border-radius: 0;
    overflow: hidden;
    background: #101722;
    box-shadow: none;
  }

  #map {
    width: 100%;
    height: 100%;
    min-height: 100vh;
    min-height: 100svh;
    background: #101722;
  }

  .wellness-marker {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #0f172a;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.55);
    transform: translateY(50%);
    border: 2px solid rgba(255, 255, 255, 0.08);
  }

  .wellness-marker img {
    width: 40px;
    height: 40px;
  }

  .route-car-marker {
    position: absolute;
    width: 44px;
    height: 68px;
    pointer-events: none;
    transform-origin: center;
    transition: transform 0.08s linear;
    will-change: transform;
    filter: drop-shadow(0 7px 12px rgba(0, 0, 0, 0.64));
  }

  .route-car-marker svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .route-car-marker.hidden {
    display: none;
  }

  .no-key {
    margin-top: 40px;
    padding: 56px 32px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
    color: var(--muted);
    text-align: center;
  }

  .no-key h3 {
    margin: 0 0 10px;
    color: var(--ink);
  }

  .no-key code {
    background: #e7ebf0;
    padding: 4px 8px;
    border-radius: 5px;
    color: var(--accent-dark);
  }

  @media (max-width: 1180px) {
    .stage-caption h4 {
      font-size: 3rem;
    }

    .service-rail {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 980px) {
    .stage-caption h4 {
      font-size: 2.55rem;
    }

    .route-layout {
      margin-top: 42px;
    }

    .heritage-content {
      grid-template-columns: 1fr;
    }

    .heritage-mark {
      justify-self: start;
      text-align: left;
    }
  }

