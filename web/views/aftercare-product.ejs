<style>
  .product-page {
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
    padding: 30px 0 48px;
  }

  .product-overview {
    margin-bottom: 28px;
  }

  .overview-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 14px;
  }

  .overview-title {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .overview-link {
    color: var(--accent);
    font-size: 0.86rem;
    font-weight: 700;
    text-decoration: none;
  }

  .overview-rail {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(150px, 1fr);
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 8px;
  }

  .overview-item {
    min-width: 150px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #fff;
    color: var(--ink);
    text-decoration: none;
    overflow: hidden;
  }

  .overview-item.active {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px rgba(28, 105, 212, 0.12);
  }

  .overview-item img {
    width: 100%;
    aspect-ratio: 1 / 1;
    display: block;
    object-fit: contain;
    padding: 14px;
    background: #f5f7f9;
  }

  .overview-item span {
    display: block;
    padding: 10px 12px 12px;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
    line-height: 1.2;
  }

  .product-detail {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(360px, 0.85fr);
    gap: 52px;
    align-items: stretch;
  }

  .product-media {
    position: relative;
    height: max(440px, calc(100vh - 142px));
    border-radius: 20px;
    background: #eee9e2;
    overflow: hidden;
  }

  .product-media img {
    position: absolute;
    inset: 0;
    width: 100%; height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .product-media:hover img {
    transform: scale(1.06);
  }

  .product-panel {
    position: sticky;
    top: 102px;
    padding: 8px 0;
    background: var(--paper);
    display: flex;
    flex-direction: column;
  }

  .product-kicker {
    margin: 0 0 14px;
    color: var(--accent);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .product-panel h1 {
    margin: 0;
    color: var(--ink);
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.05;
  }

  .product-price {
    margin: 20px 0 0;
    color: var(--ink);
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .product-description {
    max-width: 48ch;
    margin: 20px 0 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .product-meta {
    display: block;
    margin: 14px 0 0;
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .availability-box {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 14px 18px;
    margin-top: 24px;
    border: 1px solid rgba(21, 128, 61, 0.18);
    border-radius: var(--radius);
    background: #f0fdf4;
    padding: 14px 16px;
  }

  .availability-state,
  .delivery-state {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.94rem;
    font-weight: 700;
  }

  .availability-state {
    color: #15803d;
  }

  .delivery-state {
    color: var(--ink-soft);
  }

  .availability-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: #16a34a;
    box-shadow: 0 0 0 4px rgba(22, 163, 74, 0.12);
    flex: 0 0 auto;
  }

  .delivery-icon {
    width: 18px;
    height: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: #fff;
    color: var(--accent);
    font-size: 0.78rem;
    flex: 0 0 auto;
  }

  .buy-form {
    display: grid;
    gap: 18px;
    margin-top: auto;
    padding-top: 24px;
    border-top: 1px solid var(--line);
  }

  .control-grid {
    display: grid;
    grid-template-columns: minmax(150px, 220px) 1fr;
    gap: 12px;
  }

  .size-options {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .size-option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .size-option span {
    min-width: 56px;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid rgba(17, 24, 39, 0.14);
    border-radius: 10px;
    background: #fff;
    color: var(--ink);
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    transition: border-color 0.18s, background 0.18s, color 0.18s;
  }

  .size-option span:hover {
    border-color: var(--ink);
  }

  .size-option input:checked + span {
    border-color: var(--ink);
    background: var(--ink);
    color: #fff;
  }

  .action-row {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .action-row .btn {
    width: 100%;
    min-height: 54px;
    font-size: 0.88rem;
  }

  .status-line {
    min-height: 22px;
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .not-found {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #fff;
    padding: 36px;
  }

  @media (max-width: 860px) {
    .product-detail { grid-template-columns: 1fr; gap: 28px; }
    .control-grid   { grid-template-columns: 1fr; }
    .product-page   { width: min(100% - 28px, 1180px); }
    .product-media  { height: auto; aspect-ratio: 4 / 3; border-radius: 14px; }
    .product-panel  { position: static; padding: 0; }
  }
</style>

<div class="product-page">
  <% if (!product) { %>
    <div class="not-found">
      <p class="product-kicker">Aftercare</p>
      <h1>Produkt nicht gefunden</h1>
      <p class="product-description">Dieses Produkt ist nicht mehr verfügbar oder die Adresse ist falsch.</p>
      <a class="btn btn-primary" href="/aftercare-shop" style="margin-top:22px;">Zur Produktübersicht</a>
    </div>
  <% } else { %>
    <%
      const isClothing = product.category === "clothes";
      const sizes = isClothing && product.sizes
        ? String(product.sizes).split(",").map((size) => size.trim()).filter(Boolean)
        : [];
      const displayDescription = product.description
        ? String(product.description)
            .replace(/\s*im Ma[ßÃŸ]+stab\s*1:18\.?/i, ".")
            .replace(/\s+$/, "")
        : "";
      const productMeta = [
        product.gender,
        isClothing ? product.color : null,
      ].filter(Boolean).join(" / ");
      const overviewProducts = (products || []).filter((item) => item.id !== product.id);
    %>

    <section class="product-detail">
      <div class="product-media">
        <img src="<%= product.imageUrl %>" alt="<%= product.name %><% if (product.color) { %> in <%= product.color %><% } %>" />
      </div>

      <div class="product-panel">
        <p class="product-kicker"><%= product.category === "clothes" ? "Kleidung" : "Accessoire" %></p>
        <h1><%= product.name %></h1>
        <div class="product-price"><%= parseFloat(product.price).toLocaleString("de-DE", { style: "currency", currency: "EUR" }) %></div>
        <% if (displayDescription) { %>
          <p class="product-description"><%= displayDescription %></p>
        <% } %>
        <% if (productMeta) { %>
          <p class="product-meta"><%= productMeta %></p>
        <% } %>
        <div class="availability-box" aria-label="Verfügbarkeit und Lieferung">
          <div class="availability-state">
            <span class="availability-dot" aria-hidden="true"></span>
            <span>Auf Lager</span>
          </div>
          <div class="delivery-state">
            <span class="delivery-icon" aria-hidden="true">↗</span>
            <span>Voraussichtliche Lieferung in 3-5 Tagen</span>
          </div>
        </div>

        <form class="buy-form" data-product-form>
          <% if (sizes.length) { %>
            <div class="field">
              <span class="field-label">Größe</span>
              <div class="size-options">
                <% sizes.forEach(function(size, index) { %>
                  <label class="size-option">
                    <input type="radio" name="size" value="<%= size %>" <%= index === 0 ? "checked" : "" %> />
                    <span><%= size %></span>
                  </label>
                <% }) %>
              </div>
            </div>
          <% } %>

          <div class="control-grid">
            <label class="field">
              <span class="field-label">Anzahl</span>
              <input class="input" name="quantity" type="number" min="1" value="1" />
            </label>
          </div>

          <div class="action-row">
            <button class="btn btn-secondary" type="button" data-cart-button>In den Cart</button>
            <button class="btn btn-primary" type="button" data-buy-button>Direkt zur Kasse</button>
          </div>
          <div class="status-line" data-status aria-live="polite"></div>
        </form>
      </div>
    </section>

    <script>
      const product = {
        id: <%- JSON.stringify(product.id) %>,
        name: <%- JSON.stringify(product.name) %>,
        price: <%- JSON.stringify(product.price) %>,
        imageUrl: <%- JSON.stringify(product.imageUrl) %>,
        color: <%- JSON.stringify(product.color || null) %>,
        category: <%- JSON.stringify(product.category) %>,
      };

      const form = document.querySelector("[data-product-form]");
      const statusLine = document.querySelector("[data-status]");

      window.addEventListener("pageshow", () => {
        statusLine.textContent = "";
      });

      function getSelectedQuantity() {
        const quantityInput = form.querySelector('[name="quantity"]');
        const quantity = Math.max(1, parseInt(quantityInput.value, 10) || 1);
        quantityInput.value = quantity;
        return quantity;
      }

      function buildCartPayload() {
        const sizeInput = form.querySelector('[name="size"]:checked');
        const details = {
          productId: product.id,
          color: product.color,
        };

        if (sizeInput) {
          details.size = sizeInput.value;
        }

        return {
          type: "aftercare",
          name: product.name,
          price: parseFloat(product.price),
          imageUrl: product.imageUrl,
          quantity: getSelectedQuantity(),
          details,
        };
      }

      async function addToCart() {
        const response = await fetch("/api/cart/items", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(buildCartPayload()),
        });

        if (!response.ok) {
          throw new Error("cart request failed");
        }

        return response.json();
      }

      document.querySelector("[data-cart-button]").addEventListener("click", async () => {
        statusLine.textContent = "Wird hinzugefügt...";
        try {
          await addToCart();
          statusLine.textContent = "Produkt wurde in den Cart gelegt.";
        } catch (error) {
          statusLine.textContent = "Der Cart ist gerade nicht erreichbar.";
        }
      });

      document.querySelector("[data-buy-button]").addEventListener("click", async () => {
        try {
          await addToCart();
          window.location.href = "/shopping-cart?checkout=1";
        } catch (error) {
          statusLine.textContent = "Der Cart ist gerade nicht erreichbar.";
        }
      });
    </script>
  <% } %>
</div>
