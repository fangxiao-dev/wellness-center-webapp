<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= typeof title !== 'undefined' && title ? title : 'Serenity Wellness Center' %></title>
    <link rel="stylesheet" href="/static/ci/wellness-ci.css">
  </head>
  <body>
    <%
      const variant = (typeof navVariant !== 'undefined' && navVariant) ? navVariant : 'solid';
      const active = (typeof activePage !== 'undefined' && activePage) ? activePage : null;
      const navLinks = [
        { key: 'home',         href: '/',                  label: 'Home' },
        { key: 'configurator', href: '/package-configurator',  label: 'Packages' },
        { key: 'merch',        href: '/aftercare-shop',        label: 'Aftercare' },
        { key: 'visit',        href: '/visit-context',         label: 'Visit' },
        { key: 'ai',           href: '/ai-feature',        label: 'AI Consultation' },
        { key: 'cart',         href: '/shopping-cart',     label: 'Cart' },
      ];
    %>
    <nav class="site-nav site-nav--<%= variant %>" aria-label="Hauptnavigation">
      <a class="brand" href="/">
        <strong>Serenity Wellness Center</strong>
        <span>Wellness Center</span>
      </a>
      <div class="nav-links">
        <% navLinks.forEach(function(link) { %>
          <a href="<%= link.href %>"<% if (link.key === active) { %> class="active"<% } %>><%= link.label %></a>
        <% }) %>
      </div>
    </nav>

    <main><%- body %></main>

    <footer class="site-footer" id="impressum">
      <div class="page-shell footer-grid">
        <div class="footer-brand">
          <strong>Serenity Wellness Center</strong>
          <span>Elective: Cloud Based Web Development</span>
          <span class="footer-legal">Impressum: HHZ Cloud Web App Team, Hermann Hollerith Zentrum, Böblingen.</span>
          <span class="footer-legal">© 2026 HHZ Cloud Web App Team</span>
        </div>
        <nav class="footer-links" aria-label="Footer Navigation">
          <a href="/">Home</a>
          <a href="/package-configurator">Packages</a>
          <a href="/aftercare-shop">Aftercare</a>
          <a href="/visit-context">Visit</a>
          <a href="/ai-feature">AI Consultation</a>
          <a href="/impressum">Impressum</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
