<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= typeof title !== 'undefined' && title ? title : 'Serenity Wellness Center' %></title>
    <link rel="stylesheet" href="/static/styles.css" />
  </head>
  <body>
    <%
      const active = (typeof activePage !== 'undefined' && activePage) ? activePage : null;
      const navLinks = [
        { key: 'home', href: '/', label: 'Home' },
        { key: 'packages', href: '/package-configurator', label: 'Packages' },
        { key: 'ai', href: '/ai-feature', label: 'AI Consultation' },
        { key: 'aftercare', href: '/aftercare-shop', label: 'Aftercare Shop' },
        { key: 'visit', href: '/visit-context', label: 'Visit Context' },
        { key: 'cart', href: '/shopping-cart', label: 'Cart' },
      ];
    %>
    <nav class="site-nav" aria-label="Main navigation">
      <a class="brand" href="/">
        <strong>Serenity Wellness Center</strong>
        <span>Massage, recovery, aftercare</span>
      </a>
      <div class="nav-links">
        <% navLinks.forEach(function(link) { %>
          <a href="<%= link.href %>"<% if (link.key === active) { %> class="active"<% } %>><%= link.label %></a>
        <% }) %>
      </div>
    </nav>

    <main><%- body %></main>

    <footer class="site-footer">
      <div class="page-shell footer-grid">
        <div>
          <strong>Serenity Wellness Center</strong>
          <span>Cloud-based Web Application course project</span>
        </div>
        <nav class="footer-links" aria-label="Footer navigation">
          <a href="/package-configurator">Packages</a>
          <a href="/aftercare-shop">Aftercare</a>
          <a href="/visit-context">Visit Context</a>
          <a href="/impressum">Impressum</a>
        </nav>
      </div>
    </footer>
    <script>
      window.SERENITY_MAPS_KEY = "<%= typeof mapsApiKey !== 'undefined' ? mapsApiKey : '' %>";
      window.SERENITY_INITIAL_SELECTION = <%- JSON.stringify(typeof initialSelection !== 'undefined' ? initialSelection : null) %>;
    </script>
    <script src="/static/app.js"></script>
  </body>
</html>
